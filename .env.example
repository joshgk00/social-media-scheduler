# ===========================================
# Social Media Scheduler - Environment Config
# ===========================================

# --- Required ---

# PostgreSQL connection (used by api and worker services)
DATABASE_URL=postgres://scheduler:changeme@postgres:5432/scheduler

# Test-only Postgres connection for @sms/db migration runner tests.
# Points at the dev docker-compose `postgres` container on 127.0.0.1:5432 with a throwaway DB name.
# Used by packages/db/src/__tests__/helpers/test-db.ts. NOT a secret — dev-only credentials.
DATABASE_URL_TEST=postgres://scheduler:phase2password!@127.0.0.1:5432/scheduler_test

# Redis connection (used by api and worker services)
REDIS_URL=redis://:changeme@redis:6379

# Redis password (used by redis service and connection URLs)
REDIS_PASSWORD=changeme

# Encryption key for OAuth tokens (AES-256-GCM requires 32 bytes = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# CSRF secret for Double Submit Cookie pattern
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# --- PostgreSQL Container ---

POSTGRES_USER=scheduler
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scheduler

# --- Optional ---

# Application
NODE_ENV=development
LOG_LEVEL=info

# nginx exposed port on host
NGINX_PORT=8080

# Media Storage
MEDIA_STORAGE_BACKEND=local
MEDIA_DIR=./data/media
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
