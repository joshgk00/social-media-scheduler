# ===========================================
# Social Media Scheduler - Environment Config
# ===========================================

# --- Required ---

# PostgreSQL connection (used by api and worker services)
DATABASE_URL=postgres://scheduler:changeme@postgres:5432/scheduler

# Test-only Postgres connection for @sms/db migration runner tests.
# Points at the dev docker-compose `postgres` container on 127.0.0.1:5432 with a throwaway DB name.
# Used by packages/db/src/__tests__/helpers/test-db.ts. NOT a secret — dev-only credentials.
DATABASE_URL_TEST=postgres://scheduler:phase2password!@127.0.0.1:5432/scheduler_test

# Redis connection (used by api and worker services)
REDIS_URL=redis://:changeme@redis:6379

# Redis password (used by redis service and connection URLs)
REDIS_PASSWORD=changeme

# Encryption key for OAuth tokens (AES-256-GCM requires 32 bytes = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# CSRF secret for Double Submit Cookie pattern
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# Session secret for express-session
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- PostgreSQL Container ---

POSTGRES_USER=scheduler
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scheduler

# --- Optional ---

# Application
NODE_ENV=development
LOG_LEVEL=info

# nginx exposed port on host
NGINX_PORT=8080

# Media Storage
MEDIA_STORAGE_BACKEND=local
MEDIA_DIR=./data/media
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# OAuth / Token Lifecycle (Phase 7)
# LinkedIn Developer App — create at https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202604
# Facebook App — create at https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v25.0
# Public-facing base URL used to build OAuth redirect URIs (must match the
# redirect URIs registered in the LinkedIn and Facebook developer consoles).
OAUTH_REDIRECT_BASE_URL=https://localhost:8443

# ----- Phase 9: Notifications & Settings -----
# SMTP relay used by the notification worker for outbound emails.
# If any of these are unset, the worker logs a warning and runs in
# in-app-only mode (email_logs rows still recorded with status=failed).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Public-facing base URL inserted into email links. Set per-environment.
APP_BASE_URL=https://your-domain.example
# Notification worker concurrency. Default 2.
NOTIFICATION_WORKER_CONCURRENCY=2
