# ===========================================
# Social Media Scheduler - Environment Config
# ===========================================

# --- Required ---

# PostgreSQL connection (used by api and worker services)
DATABASE_URL=postgres://scheduler:changeme@postgres:5432/scheduler

# Redis connection (used by api and worker services)
REDIS_URL=redis://:changeme@redis:6379

# Redis password (used by redis service and connection URLs)
REDIS_PASSWORD=changeme

# Encryption key for OAuth tokens (AES-256-GCM requires 32 bytes = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# CSRF secret for Double Submit Cookie pattern
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# --- PostgreSQL Container ---

POSTGRES_USER=scheduler
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scheduler

# --- Optional ---

# Application
NODE_ENV=development
LOG_LEVEL=info

# nginx exposed port on host
NGINX_PORT=8080

# Media Storage
MEDIA_STORAGE_BACKEND=local
MEDIA_DIR=./data/media
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
